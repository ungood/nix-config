{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(head:*)",
      "Bash(just:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "cship"
  },
  "enabledPlugins": {
    "claude@ungood": true,
    "cli@ungood": true,
    "github@ungood": true,
    "markdown@ungood": true,
    "writing-style@ungood": true
  },
  "extraKnownMarketplaces": {
    "ungood": {
      "source": {
        "source": "github",
        "repo": "ungood/agents"
      }
    }
  },
  "feedbackSurveyRate": 0,
  "plansDirectory": ".claude/plans",
  "tui": "fullscreen",
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
